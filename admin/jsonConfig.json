{
	"i18n": true,
	"type": "panel",
	"items": {
		"_locationsHeader": {
			"type": "header",
			"text": "locations",
			"newLine": true
		},
		"locations": {
			"type": "table",
			"newLine": true,
			"items": [
				{
					"type": "text",
					"attr": "name",
					"title": "locationName",
					"width": "40%"
				},
				{
					"type": "number",
					"attr": "lat",
					"title": "latitude",
					"min": -90,
					"max": 90,
					"width": "30%"
				},
				{
					"type": "number",
					"attr": "lon",
					"title": "longitude",
					"min": -180,
					"max": 180,
					"width": "30%"
				}
			]
		},
		"_forecastHeader": {
			"type": "header",
			"text": "forecast",
			"newLine": true
		},
		"daysCount": {
			"type": "number",
			"label": "daysCount",
			"help": "daysCountHelp",
			"min": 1,
			"max": 16,
			"newLine": true,
			"xs": 12,
			"sm": 6,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"hourlyDays": {
			"type": "number",
			"label": "hourlyDays",
			"help": "hourlyDaysHelp",
			"min": 0,
			"max": 16,
			"xs": 12,
			"sm": 6,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"_unitsHeader": {
			"type": "header",
			"text": "units",
			"newLine": true
		},
		"temperatureUnit": {
			"type": "select",
			"label": "temperatureUnit",
			"options": [
				{ "label": "celsius", "value": "celsius" },
				{ "label": "fahrenheit", "value": "fahrenheit" }
			],
			"newLine": true,
			"xs": 12,
			"sm": 6,
			"md": 4,
			"lg": 3,
			"xl": 3
		},
		"windspeedUnit": {
			"type": "select",
			"label": "windspeedUnit",
			"options": [
				{ "label": "km/h", "value": "kmh" },
				{ "label": "m/s", "value": "ms" },
				{ "label": "mph", "value": "mph" },
				{ "label": "kn", "value": "kn" }
			],
			"xs": 12,
			"sm": 6,
			"md": 4,
			"lg": 3,
			"xl": 3
		},
		"precipitationUnit": {
			"type": "select",
			"label": "precipitationUnit",
			"options": [
				{ "label": "mm", "value": "mm" },
				{ "label": "inch", "value": "inch" }
			],
			"xs": 12,
			"sm": 6,
			"md": 4,
			"lg": 3,
			"xl": 3
		},
		"_iconsHeader": {
			"type": "header",
			"text": "icons",
			"newLine": true
		},
		"iconSet": {
			"type": "select",
			"label": "iconSet",
			"help": "iconSetHelp",
			"options": [
				{ "label": "WMO (OGC)", "value": "wmo" },
				{ "label": "Basmilius / Meteocons (statisch)", "value": "basmilius" },
				{ "label": "Basmilius / Meteocons (animiert SVG)", "value": "basmilius_animated" }
			],
			"newLine": true,
			"xs": 12,
			"sm": 6,
			"md": 4,
			"lg": 3,
			"xl": 3
		},
		"_iconPreview": {
			"type": "staticText",
			"newLine": true,
			"text": "iconPreviewWmo",
			"hidden": "data.iconSet !== 'wmo'"
		},
		"_iconPreviewBasmilius": {
			"type": "staticText",
			"newLine": true,
			"text": "iconPreviewBasmilius",
			"hidden": "data.iconSet !== 'basmilius'"
		},
		"_iconPreviewAnimated": {
			"type": "staticText",
			"newLine": true,
			"text": "iconPreviewAnimated",
			"hidden": "data.iconSet !== 'basmilius_animated'"
		}
	}
}
